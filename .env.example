# =====================
# AQC-N
# =====================
SECRET_KEY=replace-this-in-production

# MySQL
MYSQL_ROOT_PASSWORD=replace-root-password
DB_HOST=db
DB_PORT=3306
DB_NAME=aqc_n
DB_USER=aqc
DB_PASSWORD=replace-db-password
DB_MEM_LIMIT=768m

# Auth token
TOKEN_EXPIRE_DAYS=30
TOKEN_BYTES=48
ENABLE_LOCAL_LOGIN=false
WEB_PORT=8080
API_WORKERS=2

# Admin seed
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@aqc.local
ADMIN_PASSWORD=change-this-password

# Account-SyMuse SSO
SYMUSE_API_BASE=https://account.symuse.com/api
SYMUSE_CLIENT_ID=aqc
SYMUSE_CLIENT_SECRET=replace-aqc-client-secret
SYMUSE_AUTH_PAGE=https://account.symuse.com/auth
SYMUSE_STATE_EXPIRE_SECONDS=600
SYMUSE_STATE_REQUIRED=true
SYMUSE_STATE_IP_STRICT=false
SYMUSE_AQC_SYNC_ENABLED=true
SYMUSE_ADMIN_ACCOUNT=admin
SYMUSE_ADMIN_PASSWORD=change-this-password

# Legacy SQL import
AQCO_SQL_PATH=/legacy-data/whaqc_data.sql
AQCO_FULL_PREFIX=aqco_
AQCO_LEGACY_BRIDGE_ENABLED=true
AQCO_LEGACY_BRIDGE_BASE=https://wx.whaqc.cn/api
AQCO_LEGACY_BRIDGE_TIMEOUT=20

# Legacy order upload (compatible with AQC-O)
AQC_ORDER_UPLOAD_API_URL=https://b.kuaidi100.com/v5/open/api/send
AQC_ORDER_UPLOAD_APPID=replace-order-upload-appid
AQC_ORDER_UPLOAD_APPSECRET=replace-order-upload-appsecret
AQC_ORDER_UPLOAD_APPUID=replace-order-upload-appuid
AQC_ORDER_UPLOAD_TIMEOUT=20
AQC_ORDER_UPLOAD_SENDER_USER_ID=1
AQC_ORDER_UPLOAD_SENDER_NAME=
AQC_ORDER_UPLOAD_SENDER_MOBILE=
AQC_ORDER_UPLOAD_SENDER_ADDR=

# CORS
CORS_ORIGINS=https://aqc.symuse.com,http://localhost:5173,http://127.0.0.1:5173
