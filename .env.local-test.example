# Local-only test environment. Do not reuse these values in production.
SECRET_KEY=aqc-local-test-secret

# Isolated MySQL for local tests
MYSQL_ROOT_PASSWORD=aqc_local_test_root
DB_NAME=aqc_n_local_test
DB_USER=aqc_test
DB_PASSWORD=aqc_local_test_password
DB_MEM_LIMIT=512m
DB_POOL_SIZE=6
DB_POOL_MAX_OVERFLOW=12

# Local test login
ENABLE_LOCAL_LOGIN=true
TOKEN_EXPIRE_DAYS=7
TOKEN_BYTES=48
ADMIN_USERNAME=La
ADMIN_EMAIL=la@aqc.local
ADMIN_PASSWORD=change-this-local-password

# Local ports
LOCAL_TEST_API_PORT=18080
LOCAL_TEST_DB_PORT=13307
LOCAL_TEST_FRONTEND_PORT=5173
API_WORKERS=1

# Keep test frontend and preview origins allowed
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# External account sync is disabled in local tests.
SYMUSE_API_BASE=https://account.symuse.com/api
SYMUSE_CLIENT_ID=aqc-local-test
SYMUSE_CLIENT_SECRET=local-test-disabled
SYMUSE_AUTH_PAGE=https://account.symuse.com/auth
SYMUSE_STATE_EXPIRE_SECONDS=600
SYMUSE_STATE_REQUIRED=true
SYMUSE_STATE_IP_STRICT=false
SYMUSE_AQC_SYNC_ENABLED=false
SYMUSE_ADMIN_ACCOUNT=
SYMUSE_ADMIN_PASSWORD=

# Legacy paths and order upload stay harmless in local tests.
AQCO_SQL_PATH=/legacy-data/whaqc_data.sql
AQC_ORDER_UPLOAD_API_URL=https://b.kuaidi100.com/v5/open/api/send
AQC_ORDER_UPLOAD_APPID=local-test
AQC_ORDER_UPLOAD_APPSECRET=local-test
AQC_ORDER_UPLOAD_APPUID=local-test
AQC_ORDER_UPLOAD_TIMEOUT=5
AQC_ORDER_UPLOAD_SENDER_USER_ID=1
AQC_ORDER_UPLOAD_SENDER_NAME=
AQC_ORDER_UPLOAD_SENDER_MOBILE=
AQC_ORDER_UPLOAD_SENDER_ADDR=
