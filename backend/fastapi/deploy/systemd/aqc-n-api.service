[Unit]
Description=AQC-N FastAPI Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/aqc-n/backend/fastapi
ExecStart=/opt/aqc-n/backend/fastapi/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target

